# =========================================================================
# Sahla FCM Push Notification Broker Environment Variables Template
# =========================================================================
# Copy this file to '.env' and fill in your private service credentials.
# For Railway deployment, define these keys in the "Variables" settings tab.

# The port Express will run on. Railway automatically provides this.
PORT=8080

# -------------------------------------------------------------------------
# Supabase Secure Access Integration
# -------------------------------------------------------------------------
# Your Supabase Project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=https://bfsqamfiaohattxrxfdl.supabase.co

# Supabase SERVICE_ROLE secret key.
# IMPORTANT: This key is highly privileged and bypasses Row Level Security (RLS).
# Get from: Supabase Dashboard -> Project Settings -> API -> service_role key.
# NEVER expose this key in the frontend client code!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJmc3FhbWZpYW9oYXR0eHJ4ZmRsIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTIxNDQ1OSwiZXhwIjoyMDkwNzkwNDU5fQ.0jMxP1_hHqxc9JhAwK-Yx1pudkjS3dMgZ7gD-i2woic
# -------------------------------------------------------------------------
# Firebase Admin SDK Configuration (Preferred individual variables)
# -------------------------------------------------------------------------
# Project ID from Firebase Console -> Project Settings
FIREBASE_PROJECT_ID=sahla-study

# Client Email address from Service Account JSON key file.
# Looks like: firebase-adminsdk-xxxxx@sahla-study.iam.gserviceaccount.com
FIREBASE_CLIENT_EMAIL=your_firebase_service_account_client_email

# Private Key from Service Account JSON key file.
# Must include the entire block including headers and escaped newlines (\n).
# Looks like: "-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC..."
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# -------------------------------------------------------------------------
# Optional fallback (Entire stringified JSON credential)
# -------------------------------------------------------------------------
# If you prefer not to enter individual keys above, you can stringify the
# entire content of your service-account JSON file and paste it here:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": ...}'

# -------------------------------------------------------------------------
# REST Manual Dispatch Security (Optional)
# -------------------------------------------------------------------------
# Generate a random secret UUID to secure your "POST /api/dispatch" endpoint.
# When calling this API, provide this value in the "x-api-secret" header
# or as a Bearer Token in the Authorization header.
API_SECRET_KEY=generate_a_random_guid_for_manual_api_dispatch
